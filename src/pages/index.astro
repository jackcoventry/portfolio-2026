---
import Layout from '@/layouts/Layout.astro';
import Introduction from '@/components/Introduction.astro';
import BioBlock from '@/components/BioBlock.astro';
import data from '@/data/homepage.json';
---

<Layout>
  <Introduction title={data?.introduction?.title} text={data?.introduction?.text} />
  <BioBlock title={data?.bio?.title} text={data?.bio?.text} tools={data?.bio?.tools} />
</Layout>
