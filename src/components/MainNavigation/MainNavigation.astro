---
import TextSwap from '@/components/TextSwap/TextSwap.astro';
import { SITE_AUTHOR } from '@/consts/consts';

type NavItem = {
  externalLink: boolean;
  href: string;
  label: string;
};

interface Props {
  items: NavItem[];
}

const { items = [] } = Astro.props;
---

<a
  href="#content"
  class="skip-to-content | font-body absolute top-0 left-0 z-70 -m-px h-px w-px overflow-hidden border-0 bg-white p-0 whitespace-nowrap focus:m-0 focus:h-auto focus:w-auto focus:overflow-visible focus:p-5 focus:whitespace-normal"
  >Skip to content</a
>

<header class="absolute z-50 w-full" id="siteHeader">
  <nav id="desktopNav" class="hidden lg:block" aria-label="Primary">
    <ul class="flex h-20 items-center justify-between gap-8">
      <li>
        <a id="desktopLogo" href="/" class="inline-flex items-center gap-3">
          <span class="font-body p-6">{SITE_AUTHOR}</span>
        </a>
      </li>
      {
        items.slice(0, 3).map((item: NavItem) => {
          const openInNewTab = Boolean(item?.externalLink);
          const attributes = {
            href: item.href,
            ...(openInNewTab
              ? {
                  target: '_blank',
                  rel: 'noopener noreferrer',
                }
              : null),
          };
          return (
            <li>
              <a {...attributes} class="font-body block">
                <TextSwap text={item.label} class="flex p-6" />
              </a>
            </li>
          );
        })
      }
    </ul>

    <div id="desktopNavSentinel" class="h-px w-full" aria-hidden="true"></div>
  </nav>

  <div
    id="mobileBar"
    class="fixed top-0 right-0 left-0 z-[70] transition-opacity transition-transform motion-reduce:transition-none"
    data-at-top="true"
    data-menu-open="false"
  >
    <nav aria-label="Primary" class="px-6">
      <div class="flex h-16 items-center justify-between">
        <a
          href="/"
          id="mobileLogo"
          class="inline-flex items-center opacity-0"
          aria-hidden="true"
          tabindex="-1"
        >
          <span class="font-body">{SITE_AUTHOR}</span>
        </a>

        <button
          id="menuToggle"
          type="button"
          class="relative inline-flex h-12 w-12 cursor-pointer items-center justify-center motion-reduce:transform-none"
          aria-haspopup="dialog"
          aria-controls="mobileMenu"
          aria-expanded="false"
        >
          <span class="sr-only">Open menu</span>
          <span
            aria-hidden="true"
            class="absolute block h-px w-7 bg-black transition-opacity transition-transform motion-reduce:transition-none"
            data-line="top"></span>
          <span
            aria-hidden="true"
            class="absolute block h-px w-7 bg-black transition-opacity transition-transform motion-reduce:transition-none"
            data-line="bottom"></span>
        </button>
      </div>
    </nav>
  </div>

  <div
    id="mobileMenu"
    class="pointer-events-none fixed inset-0 z-[60] bg-white opacity-0 transition-opacity motion-reduce:transition-none"
    role="dialog"
    aria-modal="true"
    aria-label="Menu"
    tabindex="-1"
    aria-hidden="true"
    hidden
  >
    <div class="h-full w-full">
      <div class="mx-auto max-w-6xl px-6 pt-[calc(var(--nav-offset)+2rem)] pb-10">
        <ul class="space-y-6">
          {
            items.map((item: NavItem) => {
              const openInNewTab = Boolean(item?.externalLink);
              const attributes = {
                href: item.href,
                ...(openInNewTab
                  ? {
                      target: '_blank',
                      rel: 'noopener noreferrer',
                    }
                  : null),
              };
              return (
                <li>
                  <a {...attributes} class="font-heading block">
                    <TextSwap
                      text={item.label}
                      class="flex px-7 py-5 leading-[1.2em] max-lg:leading-[1.1em]"
                    />
                  </a>
                </li>
              );
            })
          }
        </ul>
      </div>
    </div>
  </div>

  <style>
    #mobileBar {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    @media (min-width: 1024px) {
      #mobileBar {
        opacity: 0;
        transform: translateY(-8px);
        pointer-events: none;
      }

      #mobileBar.bar-visible {
        opacity: 1 !important;
        transform: translateY(0) !important;
        pointer-events: auto !important;
      }
    }

    #mobileLogo.js-ready {
      transition: opacity 180ms;
    }

    @media (prefers-reduced-motion: reduce) {
      #mobileLogo.js-ready {
        transition: none;
      }
    }
  </style>
</header>

<script type="module">
  const header = document.getElementById('siteHeader');
  const desktopLogo = document.getElementById('desktopLogo');
  const mobileBar = document.getElementById('mobileBar');
  const mobileLogo = document.getElementById('mobileLogo');
  const toggle = document.getElementById('menuToggle');
  const menu = document.getElementById('mobileMenu');
  const desktopSentinel = document.getElementById('desktopNavSentinel');

  if (!header || !mobileBar || !mobileLogo || !toggle || !menu) {
    console.warn('[MainNav] Missing required elements.');
  } else {
    let isMenuOpen = false;
    let isAtTop = window.scrollY <= 0;
    let isBarVisible = !window.matchMedia('(min-width: 1024px)').matches;
    let lastFocused = null;

    const lineTop = toggle.querySelector('[data-line="top"]');
    const lineBottom = toggle.querySelector('[data-line="bottom"]');

    function applyNavOffset() {
      const h = mobileBar.offsetHeight || 0;
      document.documentElement.style.setProperty('--nav-offset', `${h}px`);
    }

    applyNavOffset();

    window.addEventListener('resize', applyNavOffset, { passive: true });

    function setPageInert(shouldInert) {
      const children = Array.from(document.body.children);
      for (const el of children) {
        if (el === header) continue;

        if (shouldInert) {
          if ('inert' in el) el.inert = true;
          el.setAttribute('aria-hidden', 'true');
        } else {
          if ('inert' in el) el.inert = false;
          el.removeAttribute('aria-hidden');
        }
      }
    }

    function setIcon(open) {
      if (!lineTop || !lineBottom) return;

      if (!open) {
        lineTop.style.transform = 'translateY(-6px) rotate(0deg)';
        lineBottom.style.transform = 'translateY(6px) rotate(0deg)';
        toggle.querySelector('.sr-only').textContent = 'Open menu';
        return;
      }

      lineTop.style.transform = 'translateY(0px) rotate(45deg)';
      lineBottom.style.transform = 'translateY(0px) rotate(-45deg)';
      toggle.querySelector('.sr-only').textContent = 'Close menu';
    }

    function setLogoVisibility() {
      const shouldShow = isMenuOpen || (isBarVisible && isAtTop);

      mobileLogo.style.opacity = shouldShow ? '1' : '0';
      mobileLogo.style.pointerEvents = shouldShow ? 'auto' : 'none';

      if (shouldShow) {
        mobileLogo.removeAttribute('tabindex');
        mobileLogo.setAttribute('aria-hidden', 'false');
      } else {
        mobileLogo.setAttribute('tabindex', '-1');
        mobileLogo.setAttribute('aria-hidden', 'true');
      }
    }

    function setBarFocusable(shouldBeFocusable) {
      if (isMenuOpen) shouldBeFocusable = true;

      if (shouldBeFocusable) {
        if ('inert' in mobileBar) mobileBar.inert = false;
        mobileBar.removeAttribute('aria-hidden');
        toggle.removeAttribute('tabindex');
        toggle.removeAttribute('aria-hidden');
      } else {
        if ('inert' in mobileBar) mobileBar.inert = true;
        mobileBar.setAttribute('aria-hidden', 'true');
        toggle.setAttribute('tabindex', '-1');
        toggle.setAttribute('aria-hidden', 'true');
        mobileLogo.setAttribute('tabindex', '-1');
        mobileLogo.setAttribute('aria-hidden', 'true');
      }
    }

    function setBarVisible(shouldShow) {
      if (isMenuOpen) shouldShow = true;

      isBarVisible = shouldShow;

      const isDesktop = window.matchMedia('(min-width: 1024px)').matches;
      if (isDesktop) {
        mobileBar.classList.toggle('bar-visible', shouldShow);
      } else {
        mobileBar.classList.add('bar-visible');
      }

      setBarFocusable(shouldShow || !isDesktop);
      setLogoVisibility();
    }

    function lockScroll() {
      const scrollBarWidth = window.innerWidth - document.documentElement.clientWidth;
      document.documentElement.style.overflow = 'hidden';
      document.body.style.overflow = 'hidden';
      if (scrollBarWidth > 0) document.body.style.paddingRight = scrollBarWidth + 'px';
    }

    function unlockScroll() {
      document.documentElement.style.overflow = '';
      document.body.style.overflow = '';
      document.body.style.paddingRight = '';
    }

    function getFocusable(root) {
      const selectors = [
        'a[href]',
        'button:not([disabled])',
        'input:not([disabled])',
        'select:not([disabled])',
        'textarea:not([disabled])',
        '[tabindex]:not([tabindex="-1"])',
      ];
      return Array.from(root.querySelectorAll(selectors.join(','))).filter(
        (el) => !!(el.offsetWidth || el.offsetHeight || el.getClientRects().length)
      );
    }

    function getTrapScopeFocusable() {
      const focusables = [...getFocusable(mobileBar), ...getFocusable(menu)];
      const seen = new Set();
      return focusables.filter((el) => {
        if (seen.has(el)) return false;
        seen.add(el);
        return true;
      });
    }

    function trapFocus(e) {
      if (!isMenuOpen || e.key !== 'Tab') return;

      const focusables = getTrapScopeFocusable();
      if (!focusables.length) {
        e.preventDefault();
        return;
      }

      const first = focusables[0];
      const last = focusables[focusables.length - 1];

      if (!mobileBar.contains(document.activeElement) && !menu.contains(document.activeElement)) {
        e.preventDefault();
        toggle.focus();
        return;
      }

      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }

    function onKeyDown(e) {
      if (e.key === 'Escape') {
        e.preventDefault();
        closeMenu();
        return;
      }
      trapFocus(e);
    }

    function onMenuClick(e) {
      const target = e.target;
      const clickedLink = target && target.closest && target.closest('a');
      if (clickedLink) {
        closeMenu();
        return;
      }

      const content = menu.querySelector('.mx-auto.max-w-6xl');
      if (content && !content.contains(target)) closeMenu();
    }

    function openMenu() {
      if (isMenuOpen) {
        toggle.focus();
        return;
      }

      isMenuOpen = true;
      lastFocused = document.activeElement;

      setBarVisible(true);

      mobileBar.dataset.menuOpen = 'true';
      toggle.setAttribute('aria-expanded', 'true');

      menu.hidden = false;
      menu.setAttribute('aria-hidden', 'false');
      requestAnimationFrame(() => {
        menu.classList.remove('pointer-events-none');
        menu.style.opacity = '1';
      });

      setPageInert(true);
      lockScroll();
      setIcon(true);
      setLogoVisibility();

      toggle.focus();

      document.addEventListener('keydown', onKeyDown, true);
      menu.addEventListener('click', onMenuClick);
    }

    function closeMenu() {
      if (!isMenuOpen) return;
      isMenuOpen = false;

      mobileBar.dataset.menuOpen = 'false';
      toggle.setAttribute('aria-expanded', 'false');

      menu.style.opacity = '0';
      menu.classList.add('pointer-events-none');
      menu.setAttribute('aria-hidden', 'true');

      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const t = reduce ? 0 : 180;
      window.setTimeout(() => {
        menu.hidden = true;
      }, t);

      setPageInert(false);
      unlockScroll();
      setIcon(false);
      setLogoVisibility();

      document.removeEventListener('keydown', onKeyDown, true);
      menu.removeEventListener('click', onMenuClick);

      if (lastFocused && typeof lastFocused.focus === 'function') lastFocused.focus();
    }

    function toggleMenu() {
      isMenuOpen ? closeMenu() : openMenu();
    }

    function updateAtTop() {
      isAtTop = window.scrollY <= 0;
      mobileBar.dataset.atTop = String(isAtTop);
      setLogoVisibility();
    }

    function setupDesktopObserver() {
      const mq = window.matchMedia('(min-width: 1024px)');

      if (!mq.matches) {
        setBarVisible(true);
        return;
      }

      setBarVisible(false);

      if (!desktopSentinel) return;

      const io = new IntersectionObserver((entries) => {
        const entry = entries[0];
        setBarVisible(!entry.isIntersecting);
      });

      io.observe(desktopSentinel);

      mq.addEventListener('change', () => {
        if (!mq.matches) setBarVisible(true);
        else setBarVisible(false);
      });
    }

    function isTypingTarget(el) {
      if (!el) return false;
      const tag = el.tagName ? el.tagName.toLowerCase() : '';
      return (
        tag === 'input' || tag === 'textarea' || tag === 'select' || el.isContentEditable === true
      );
    }

    function onGlobalShortcut(e) {
      if (!e.altKey) return;
      if (e.ctrlKey || e.metaKey) return;

      const isK = e.code === 'KeyK' || (typeof e.key === 'string' && e.key.toLowerCase() === 'k');
      if (!isK) return;

      if (isTypingTarget(document.activeElement)) return;

      e.preventDefault();
      e.stopPropagation();

      const isDesktop = window.matchMedia('(min-width: 1024px)').matches;
      const fixedBarHidden = isDesktop && !mobileBar.classList.contains('bar-visible');

      if (isDesktop && fixedBarHidden && desktopLogo) {
        desktopLogo.focus();
        return;
      }

      openMenu();
    }

    setIcon(false);
    setupDesktopObserver();
    setLogoVisibility();
    mobileLogo.classList.add('js-ready');

    toggle.addEventListener('click', toggleMenu, { passive: true });
    window.addEventListener('scroll', updateAtTop, { passive: true });
    document.addEventListener('keydown', onGlobalShortcut, true);
  }
</script>
