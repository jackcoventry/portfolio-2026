---
import TextSwap from '@/components/TextSwap/TextSwap.astro';

export type Props = {
  href: string;
  text: string;
  title: string;
};

const { title, text, href } = Astro.props;
---

<div class="text-swapper relative flex flex-col gap-4">
  <h3 class="font-sub-heading">{title}</h3>
  <p class="font-body text-secondary">{text}</p>
  <a href={href} target="_blank" class="font-title work-tile-link">
    <TextSwap text="Visit project" />
  </a>
</div>

<style>
  .work-tile-link::before {
    cursor: pointer;
    content: '';
    display: block;
    height: 100%;
    left: 0;
    position: absolute;
    top: 0;
    width: 100%;
  }
</style>
