---
type Props = {
  title: string;
  text?: string;
  tools: Array<string>;
};

const { title, text, tools } = Astro.props;
---

<section class="min-h-dvh bg-neutral-50">
  <div class="mx-auto p-7">
    <img src="/ocean.webp" />
    <h1 class="font-heading">
      {title}
    </h1>
    <p set:html={text} class="font-sub-heading pt-6 text-left" />
    <h2 class="font-sub-heading">TOOLS</h2>
    <ul>
      {tools?.map((tool) => <p>{tool}</p>)}
    </ul>
  </div>

  <img src="/me.webp" />
</section>
