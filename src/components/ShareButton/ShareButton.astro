---
const { url } = Astro.props;
---

<button
  type="button"
  data-share-btn
  data-share-url={url}
  aria-live="polite"
  aria-atomic="true"
  class="font-body relative cursor-pointer"
>
  <span data-label>Share link</span>
  <span data-copied class="absolute top-auto left-0">Copied!</span>
</button>

<style>
  button [data-label] {
    opacity: 1;
  }

  button [data-copied] {
    opacity: 0;
  }

  button[data-copied='true'] [data-label] {
    opacity: 0;
  }

  button[data-copied='true'] [data-copied] {
    opacity: 1;
  }
</style>

<script>
  import { copied, flashCopied } from '@/store/share.js';

  const btn = document.querySelector('[data-share-btn]') as HTMLElement;
  if (!btn) throw new Error('Share button not found');

  const url = btn.dataset.shareUrl;
  if (!url) throw new Error('Missing data-share-url');

  copied.subscribe((isCopied) => {
    btn.dataset.copied = String(isCopied);
  });

  btn.addEventListener('click', async () => {
    if (navigator.share) {
      try {
        await navigator.share({ url, title: document.title });
        flashCopied();
        return;
      } catch {}
    }

    try {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(url);
        flashCopied();
        return;
      }
    } catch {}

    const ta = document.createElement('textarea');
    ta.value = url;
    ta.setAttribute('readonly', '');
    ta.style.position = 'fixed';
    ta.style.top = '-9999px';
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    ta.remove();

    flashCopied();
  });
</script>
