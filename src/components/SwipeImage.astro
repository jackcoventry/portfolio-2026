---
export type SwipeRevealProps = {
  threshold?: number;
  delayMs?: number;
  durationMs?: number;
  easing?: string;
  aspectRatio?: string;
  class?: string;
};

const {
  threshold = 0.25,
  durationMs = 1100,
  delayMs = 0,
  easing = 'cubic-bezier(0.12, 1, 0.24, 1)',
  aspectRatio,
  class: className = '',
} = Astro.props;
---

<div
  class={`swipe-image ${className}`}
  data-swipe-image
  data-threshold={threshold}
  style={`--dur:${durationMs}ms; --delay:${delayMs}ms; --ease:${easing}; ${aspectRatio ? `--ar:${aspectRatio};` : ''}`}
>
  <div class="swipe-image__content">
    <slot />
  </div>
</div>

<style>
  .swipe-image {
    aspect-ratio: var(--ar);
  }

  .swipe-image__content {
    clip-path: inset(0 100% 0 0);
    filter: blur(1px);
    transform: translateX(-1.5%) scale(1.02);
    will-change: clip-path, transform, filter;
  }

  .swipe-image[data-revealed='true'] .swipe-image__content {
    clip-path: inset(0 0 0 0);
    filter: blur(0);
    transform: translateX(0) scale(1);
    transition:
      clip-path var(--dur) var(--ease) var(--delay),
      transform calc(var(--dur) + 180ms) cubic-bezier(0.12, 0.95, 0.18, 1) var(--delay),
      filter calc(var(--dur) + 180ms) cubic-bezier(0.12, 0.95, 0.18, 1) var(--delay);
  }

  .swipe-image[data-resetting='true'] .swipe-image__content {
    transition: none !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .swipe-image__content {
      filter: none;
      transform: none;
    }
    .swipe-image[data-revealed='true'] .swipe-image__content {
      transition: none;
    }
  }
</style>

<script is:inline>
  (() => {
    const OBS_MAP = (globalThis.__SWIPE_REVEAL_OBS__ ??= new WeakMap());

    const buildThresholds = () => {
      const steps = 20;
      return Array.from({ length: steps + 1 }, (_, i) => i / steps);
    };

    const reset = (el) => {
      el.dataset.resetting = 'true';
      el.removeAttribute('data-revealed');
      el.getBoundingClientRect(); // force style flush
      requestAnimationFrame(() => el.removeAttribute('data-resetting'));
    };

    const arm = (el) => {
      const old = OBS_MAP.get(el);
      if (old) old.disconnect();

      const threshold = Number(el.dataset.threshold ?? '0.25');

      const obs = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            if (entry.intersectionRatio >= threshold) {
              requestAnimationFrame(() => (el.dataset.revealed = 'true'));
              obs.disconnect();
              break;
            }
          }
        },
        { threshold: buildThresholds() }
      );

      obs.observe(el);
      OBS_MAP.set(el, obs);
    };

    const initAll = () => {
      const els = document.querySelectorAll('[data-swipe-image]');
      for (const el of els) {
        reset(el);
        arm(el);
      }
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAll, { once: true });
    } else {
      initAll();
    }

    window.addEventListener('pageshow', initAll);
    document.addEventListener('astro:page-load', initAll);
  })();
</script>
